{
  "name": "mpegts-react",
  "version": "0.4.1",
  "type": "module",
  "description": "React component for mpegts.js video streaming player",
  "keywords": [
    "react",
    "mpegts",
    "flv",
    "live-streaming",
    "player"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huangzida/mpegts-vue3.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && node ../../scripts/fix-dts.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "mpegts.js": "^1.8.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "mpegts.js": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0"
  }
}
