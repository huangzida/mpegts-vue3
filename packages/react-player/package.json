{
  "name": "mpegts-react",
  "version": "0.3.1",
  "type": "module",
  "description": "React component for mpegts.js video streaming player",
  "keywords": [
    "react",
    "mpegts",
    "flv",
    "live-streaming",
    "player"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huangzida/mpegts-vue3.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && node -e \"const fs=require('fs'),d='dist';fs.readdirSync(d).filter(f=>f.startsWith('index-')&&f.endsWith('.d.ts')).forEach(f=>fs.renameSync(d+'/'+f,d+'/index.d.ts'));fs.readdirSync(d).filter(f=>f.startsWith('index-')&&f.endsWith('.d.cts')).forEach(f=>fs.renameSync(d+'/'+f,d+'/index.d.cts'))\""
  },
  "peerDependencies": {
    "mpegts.js": "^1.8.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^17.0.80",
    "mpegts.js": "^1.8.0",
    "react": "^17.0.2",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0"
  }
}
