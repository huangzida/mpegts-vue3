{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "detail": "启动 apps/demo 开发服务器（pnpm -C apps/demo dev）",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^\\s*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE|vite",
          "endsPattern": "ready in|Local:"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "build",
      "detail": "递归构建所有包（pnpm -r run build）",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "release",
      "detail": "release-it 发布",
      "type": "npm",
      "script": "release",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
